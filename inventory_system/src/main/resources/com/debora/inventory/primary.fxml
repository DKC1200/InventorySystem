<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.debora.inventory.PrimaryController">
   <children>
      <Label text="Add a new item" />

      <Label text="Name:" />
      <TextField fx:id="nameField"/>

      <Label text="Price:" />
      <TextField fx:id="priceField"/>
      
      <Label text="Quantity:" />
      <TextField fx:id="quantityField"/>

      <Button fx:id="addButton" text="Add" onAction="#addItem"/>

      <TableView fx:id="table">
         <columns>
            <TableColumn fx:id="nameColumn" text="Name"/>
            <TableColumn fx:id="priceColumn" text="Price"/>
            <TableColumn fx:id="quantityColumn" text="Quantity"/>
            <TableColumn fx:id="addColumn" text="+"/>
            <TableColumn fx:id="removeColumn" text="-"/>
            <TableColumn fx:id="deleteColumn" text="Delete"/>
         </columns>
      </TableView>

   </children>

   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.debora.inventory.PrimaryController">
   <children>
      <Label text="Add a new item" />

      <VBox alignment="CENTER_LEFT" spacing="10">
         <children>
            <HBox spacing="10" alignment="CENTER_LEFT">
               <children>
                  <Label text="Name:     " />
                  <TextField fx:id="nameField"/>
               </children>
               <padding>
                  <Insets top="10" right="10" bottom="10" left="10"/>
               </padding>
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT">
               <children>
                  <Label text="Price:       " />
                  <TextField fx:id="priceField"/>
               </children>
               <padding>
                  <Insets top="10" right="10" bottom="10" left="10"/>  
               </padding>
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT">
               <children>
                  <Label text="Quantity: " />
                  <TextField fx:id="quantityField"/>
               </children>
               <padding>
                  <Insets top="10" right="10" bottom="10" left="10"/>
               </padding>
            </HBox>

            <Button fx:id="addButton" text="Add" onAction="#addItem"/>
         </children>
         <padding>
            <Insets top="10" right="10" bottom="10" left="10"/>
         </padding>
      </VBox>

      <Label text="Inventory" />

      <HBox spacing="10" alignment="CENTER_LEFT">
         <children>
            <Label fx:id="searchLabel" text="Search:" />
            <TextField fx:id="searchField" onKeyReleased="#searchItems"/>
         </children>
         <padding>
            <Insets top="10" right="10" bottom="10" left="10"/>
         </padding>
      </HBox>


      <TableView fx:id="table">
         <columns>
            <TableColumn fx:id="nameColumn" text="Name"/>
            <TableColumn fx:id="priceColumn" text="Price"/>
            <TableColumn fx:id="quantityColumn" text="Quantity"/>
            <TableColumn fx:id="totalValueColumn" text="Total Value"/>
            <TableColumn fx:id="addColumn" text="+"/>
            <TableColumn fx:id="removeColumn" text="-"/>
            <TableColumn fx:id="deleteColumn" text="Delete"/>
         </columns>
      </TableView>
      
      <VBox alignment="CENTER_LEFT" spacing="10">
         <children>
            <Label fx:id="totalValueLabel" text="Total Inventory Value: $0.00" />
            <Label fx:id="totalItemsLabel" text="Total Items: 0" />
         </children>
      </VBox>
   </children>

   <padding>
      <Insets top="10" right="10" bottom="10" left="10"/>
   </padding>
</VBox>
